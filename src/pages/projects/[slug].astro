---
import BaseLayout from "@/layouts/base.astro";
import Breadcrumb from "@/components/ui/breadcrumb.astro";

import ArrowUpRightIcon from "@/components/icons/arrow-up-right.astro";

import { projects } from "@/data/projects-content";

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.detailsUrl },
		props: { project },
	}));
}

const { project } = Astro.props;
---

<BaseLayout>
  <Breadcrumb lastPage="projects" actualPage={project.title} />

  <article class="space-y-6 animate-fade-in">
    <a href={project.href} target="_blank">
      <img 
        src={project.image} 
        alt={project.title + " landing page preview"} 
        class="w-full rounded-lg border border-gray-100 object-cover hover:opacity-90 transition-opacity duration-500"
      />
    </a>

    <div class="space-y-4 mt-6">
      <h1 class="text-[15px] sm:text-[16px] font-[450] text-black leading-[90%]">{project.title}</h1>

      <div class="flex flex-wrap gap-2">
        {project.tags.map((tag) => (
          <span class="px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded-full">
            {tag}
          </span>
        ))}
      </div>

      <p class="text-sm sm:text-[15px] font-normal text-gray-900 leading-[160%] whitespace-pre-line prose">
        {project.longDescription}
      </p>

      <div class="flex gap-4 pt-4">
        {project.href && (
          <a 
            href={project.href} 
            target="_blank"
            class="text-sm bg-gray-200 px-4 py-2 rounded-sm hover:bg-gray-300/80 transition-colors duration-500"
          >
            visit site
          </a>
        )}
        {project.repository && (
          <a 
            href={project.repository} 
            target="_blank"
            class="text-sm flex items-center gap-1.5 text-secondary hover:text-primary transition-colors duration-500"
          >
            github <ArrowUpRightIcon />
          </a>
        )}
      </div>
    </div>
  </article>
</BaseLayout>
