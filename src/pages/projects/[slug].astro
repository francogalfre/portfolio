---
import BaseLayout from "@/layouts/base.astro";
import { projects } from "@/data/projects-content";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.detailsUrl },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout>
  <a href="/projects" class="text-sm text-secondary hover:text-primary transition-colors">
    ← back to projects
  </a>

  <article class="space-y-6 animate-fade-in">
    <img 
      src={project.image} 
      alt={project.title} 
      class="w-full rounded-lg border border-gray-200"
    />

    <div class="space-y-4">
      <h1 class="text-2xl font-semibold text-black">{project.title}</h1>

      <div class="flex flex-wrap gap-2">
        {project.tags.map((tag) => (
          <span class="px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded-full">
            {tag}
          </span>
        ))}
      </div>

      <p class="text-gray-700 leading-relaxed">
        {project.longDescription}
      </p>

      <div class="flex gap-4 pt-4">
        {project.href && (
          <a 
            href={project.href} 
            target="_blank"
            class="text-sm text-primary hover:underline"
          >
            visit site →
          </a>
        )}
        {project.repository && (
          <a 
            href={project.repository} 
            target="_blank"
            class="text-sm text-secondary hover:text-primary transition-colors"
          >
            github →
          </a>
        )}
      </div>
    </div>
  </article>
</BaseLayout>
