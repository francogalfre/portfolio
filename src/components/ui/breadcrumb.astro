---
import BreadcrumbChevron from "@/components/icons/breadcrumb-chevron.astro";

const { lastPage, actualPage } = Astro.props;

let href = lastPage;

if (lastPage === "home") {
	href = "/";
}
---

<div class="flex items-center gap-1 w-full text-[15px] animate-fade-in">
  <a href={href} class="text-secondary">{lastPage}</a>
  <span class="text-secondary"><BreadcrumbChevron /></span>
  <span>{actualPage}</span>
</div>