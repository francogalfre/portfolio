---
interface Props {
	coreName: string;
}

const { coreName } = Astro.props;

const controls = {
	"↑ W": "Arriba",
	"↓ S": "Abajo",
	"← A": "Izquierda",
	"→ D": "Derecha",
	Z: coreName === "snes" ? "A" : "Botón 1",
	X: coreName === "snes" ? "B" : "Botón 2",
	C: coreName === "snes" ? "X" : "Botón 3",
	V: coreName === "snes" ? "Y" : "Botón 4",
	Enter: "Pausa",
};
---

<div class="w-full mt-8 rounded-lg bg-gray-900/50 border border-gray-700 p-6">
  <h3 class="text-lg font-bold text-white mb-4">🎮 Controles</h3>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
    {
      Object.entries(controls).map(([key, action]) => (
        <div class="flex items-center gap-3 p-3 rounded bg-gray-800/50 border border-gray-700">
          <kbd class="px-2 py-1 bg-gray-950 border border-gray-600 rounded text-yellow-400 font-mono text-sm">
            {key}
          </kbd>
          <span class="text-gray-300 text-sm">{action}</span>
        </div>
      ))
    }
  </div>

  <div class="mt-4 p-3 rounded bg-blue-900/20 border border-blue-700/30 text-blue-200 text-sm">
    💡 <strong>Tip:</strong> Haz clic en el juego antes de usar el teclado. Puedes usar el mouse o controles
    de pantalla si están disponibles.
  </div>
</div>
