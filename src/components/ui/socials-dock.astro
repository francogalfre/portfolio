---
import { HugeiconsIcon } from "@hugeicons/react";
import {
	Github01Icon,
	Linkedin01Icon,
	Mail01Icon,
	NewTwitterIcon,
} from "@hugeicons/core-free-icons";

const socials = [
	{
		name: "GitHub",
		href: "https://github.com/francogalfre",
		icon: Github01Icon,
	},
	{
		name: "LinkedIn",
		href: "https://linkedin.com/in/francogalfre",
		icon: Linkedin01Icon,
	},
	{
		name: "Twitter",
		href: "https://x.com/francogalfredev",
		icon: NewTwitterIcon,
	},
	{
		name: "Email",
		href: "mailto:francogalfre.work@gmail.com",
		icon: Mail01Icon,
	},
];
---

<div
  id="socials-dock"
  class="fixed bottom-0 left-1/2 -translate-x-1/2 flex items-center gap-3 px-6 py-2 bg-white/90 backdrop-blur-md rounded-t-xl border border-gray-200 border-b-0 transition-all duration-300 ease-out"
>
  {
    socials.map((social) => (
      <a
        href={social.href}
        target="_blank"
        rel="noopener noreferrer"
        class="p-2 text-secondary hover:text-primary transition-all duration-300 hover:scale-110 rounded-full hover:bg-gray-100/50"
        aria-label={social.name}
      >
        <HugeiconsIcon icon={social.icon} size={24} />
      </a>
    ))
  }
</div>
