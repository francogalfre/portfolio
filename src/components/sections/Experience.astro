---
import Briefcase from "../icons/Briefcase.astro";

import { experiences } from "../../data/experience";

import { getLangFromURL } from "../../i18n";
import { t } from "../../i18n";

const lang = getLangFromURL(Astro.url);
---

<div class="space-y-6">
  <header class="flex items-center justify-start gap-2 opacity-90">
    <Briefcase />
    <h2 class="text-lg">{t("experience.title")}</h2>
  </header>
  <main>
    <ul class="relative pl-8 border-l border-black/20 dark:border-white/20">
      {
        experiences.map((experience) => (
          <li class="relative space-y-6 mb-12 last:mb-0">
            <div class="absolute -left-[38px] top-5 z-10 w-3 h-3 rounded-full bg-gray-300 dark:bg-gray-500 border-2 border-black/10 dark:border-white/10" />

            <div>
              <div class="space-y-1">
                <a
                  href={experience.companyUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block text-md cursor-pointer text-black/80 dark:text-white/80 hover:text-black dark:hover:text-white transition-colors duration-300 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[1px] after:bg-black/30 dark:after:bg-white/30 hover:after:w-full after:transition-all after:duration-300"
                >
                  {experience.company}
                </a>
                <h2 class="text-xl font-medium">{experience.role}</h2>
              </div>
              <p class="pt-2 text-black/50 dark:text-white/50">
                {experience.startDate} - {experience.endDate}
              </p>
            </div>
            <p class="prose text-pretty leading-6 text-black/50 dark:text-white/50">
              {lang == "es" ? experience.summaryEs : experience.summaryEn}
            </p>
          </li>
        ))
      }
    </ul>
  </main>
</div>
