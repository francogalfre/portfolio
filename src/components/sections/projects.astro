---
import { projects } from "@/data/projects-content";

import { ArrowRight01Icon } from "@hugeicons/core-free-icons";
import { HugeiconsIcon } from "@hugeicons/react";
---

<section class="space-y-6 animate-fade-in">
  <div class="space-y-6" >
    <div class="space-y-2">
      <h2 class="text-[15px] sm:text-[16px] font-[450] text-black leading-[90%]">my projects</h2>
      <p class="text-sm sm:text-[15px] font-normal text-gray-900 leading-[160%]">
        A collection of projects I've built — from CLI tools to full-stack web applications. Each one is a chance to learn and build something useful.
      </p>
    </div>
    
    <hr class=" text-gray-200" />

    <ul class="projects-list flex flex-col gap-1.5">
      {projects.map((proj) => (
        <li class="project-item space-y-2 hover:bg-gray-100/70 transition-colors duration-500 rounded-lg py-2 px-3 -mx-3">
          <a href={`/projects/${proj.detailsUrl}`} class="flex items-center w-full justify-between gap-4">
            <div class="flex flex-col gap-1.5 py-2">
              <h4 class="text-[14px] sm:text-[15px] font-[450] text-black leading-[90%]">{proj.title}</h4>
              <p class="text-sm sm:text-[15px] text-secondary mt-0.5 leading-[120%]">{proj.description}</p>
            </div>
            <span class="text-secondary hidden sm:flex"><HugeiconsIcon icon={ArrowRight01Icon} size={16} /></span>
          </a>
        </li>
      ))}
    </ul>

<style>
  .project-item {
    transition: opacity 0.4s ease, filter 0.4s ease;
  }
  .projects-list:hover .project-item {
    opacity: 0.5;
    filter: blur(0.4px);
  }
  .projects-list:hover .project-item:hover {
    opacity: 1;
    filter: blur(0);
  }
</style>
  </div>
</section>